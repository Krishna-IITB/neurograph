# ============================================================================
# NeuroGraph environment configuration
# Copy this file to `.env` and fill in your values. Never commit `.env`.
# ============================================================================

# ----- LLM provider --------------------------------------------------------
# Options: "groq" (default, recommended) or "ollama" (local, requires Ollama running)
LLM_PROVIDER=groq

# Groq (https://console.groq.com — free tier)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama (only used if LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ----- Embeddings ----------------------------------------------------------
# Local model — no API key needed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ----- Vector DB (ChromaDB, local persistence) -----------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=neurograph

# ----- Graph DB (Neo4j AuraDB free tier) -----------------------------------
# Sign up: https://neo4j.com/cloud/aura-free
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# ----- Semantic cache (Upstash Redis free tier) ----------------------------
# Sign up: https://upstash.com — pick "Redis"
REDIS_URL=redis://default:xxxxx@xxxxx.upstash.io:6379
CACHE_THRESHOLD=0.95

# ----- Chunking ------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ----- Retrieval -----------------------------------------------------------
TOP_K_VECTOR=5
GRAPH_HOPS=2

# ----- API / UI ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501
LOG_LEVEL=INFO
